APP_NAME=SIFOBI
APP_ENV=production
# Generate di server dengan: /www/server/php/84/bin/php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://sifobi.mykopiogroup.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=daily
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=database_sifobi_prod
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=file
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_COOKIE=sifobi_session
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=public

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@mykopiogroup.com
MAIL_FROM_NAME="SIFOBI"

# ============================================
# INTEGRASI OCIA (untuk MKO Group)
# Kosongkan jika tidak pakai
# ============================================
OCIA_BASE_URL=https://ocia.mykopiogroup.com
OCIA_API_TOKEN=

# ============================================
# PAYLABS (untuk versi SaaS mandiri)
# Kosongkan jika tidak pakai
# ============================================
PAYLABS_MERCHANT_ID=
PAYLABS_API_KEY=
PAYLABS_SECRET_KEY=
PAYLABS_BASE_URL=https://api.paylabs.co.id

# ============================================
# BRANDING (opsional, bisa juga diset via UI)
# Jika diset di .env, akan jadi default saat fresh install.
# Setelah install, bisa diubah via /settings/app.
# ============================================

# Initial production users. Isi sebelum deploy-fresh, lalu ganti password setelah login.
SIFOBI_PROD_ADMIN_PASSWORD=
SIFOBI_PROD_STAFF_PASSWORD=

VITE_APP_NAME="${APP_NAME}"
